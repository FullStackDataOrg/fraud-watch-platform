{
  "title": "ML Monitoring",
  "uid": "ml-monitoring",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Predictions / min",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(fraud_predictions_total[1m]) * 60",
          "legendFormat": "{{risk_tier}} / {{feature_source}}",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 2,
      "title": "API Latency Percentiles",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(fraud_prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "P50",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.95, rate(fraud_prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "P95",
          "datasource": "Prometheus"
        },
        {
          "expr": "histogram_quantile(0.99, rate(fraud_prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "P99",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Model Version",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "fraud_model_version",
          "legendFormat": "version",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "title": "Cache Hit Rate",
      "type": "stat",
      "gridPos": { "x": 4, "y": 8, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "rate(fraud_feature_cache_hits_total[5m]) / (rate(fraud_feature_cache_hits_total[5m]) + rate(fraud_feature_cache_misses_total[5m]))",
          "legendFormat": "hit rate",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.9 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 5,
      "title": "Total Predictions",
      "type": "stat",
      "gridPos": { "x": 8, "y": 8, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(fraud_predictions_total)",
          "legendFormat": "total",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 6,
      "title": "High Risk Predictions / min",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "rate(fraud_predictions_total{risk_tier='high'}[1m]) * 60",
          "legendFormat": "high risk/min",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 7,
      "title": "Risk Tier Breakdown",
      "type": "piechart",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "sum by (risk_tier) (fraud_predictions_total)",
          "legendFormat": "{{risk_tier}}",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 8,
      "title": "Fraud Probability Distribution",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "rate(fraud_probability_distribution_bucket[5m])",
          "legendFormat": "le={{le}}",
          "datasource": "Prometheus"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      }
    }
  ]
}
